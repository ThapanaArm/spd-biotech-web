# Copy to .env.local and fill in the values.

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only secret (Dashboard → Project Settings → API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# ── Back office login ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Long random string used to sign the session cookie (e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret
